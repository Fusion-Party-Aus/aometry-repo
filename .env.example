# Plugin-specific environment variables for the Fusion governance modules.
# These are declared in manifest.json for the Aometry host to wire up.
# Copy to .env and fill in values if running outside the host bot.

# ── Social Auth pipeline ──────────────────────────────────────────────────────
# Channel snowflake for the standing #auth-queue message (required)
QUEUE_CHANNEL_ID=

# Guild ID to register module slash commands in (omit for global commands)
# DISCORD_GUILD_ID=

# ── Fedica integration (optional — stub mode active without this) ─────────────
# Bearer token for the Fedica API
# FEDICA_API_KEY=

# Override Fedica base URL (default: https://api.fedica.com/api)
# FEDICA_API_URL=

# ── LLM risk assessment (optional — stub mode active without this) ────────────
# Anthropic API key for AI risk assessment in the social-auth pipeline
# LLM_API_KEY=

# Claude model to use for risk assessment (e.g. claude-sonnet-5)
# LLM_MODEL=

# URL for policy RAG retrieval (optional)
# POLICY_INDEX_URL=
