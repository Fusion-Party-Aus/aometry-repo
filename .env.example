# Plugin-specific environment variables for the Fusion governance modules.
# These are declared in manifest.json for the Aometry host to wire up.
# Copy to .env and fill in values if running outside the host bot.

# Guild ID to register module slash commands in (omit for global commands)
# DISCORD_GUILD_ID=

# ── Social Auth pipeline ──────────────────────────────────────────────────────
# Channel snowflake for the standing #auth-queue message (required)
QUEUE_CHANNEL_ID=

# ── Fedica integration (optional — stub mode active without this) ─────────────
# Bearer token for the Fedica API
# FEDICA_API_KEY=

# Override Fedica base URL (default: https://api.fedica.com/api)
# FEDICA_API_URL=

# ── LLM risk assessment (optional — stub mode active without this) ────────────
# Anthropic API key for AI risk assessment in the social-auth pipeline
# LLM_API_KEY=

# Claude model to use for risk assessment (e.g. claude-sonnet-5)
# LLM_MODEL=

# URL for policy RAG retrieval (optional)
# POLICY_INDEX_URL=

# ── Comms Calendar (optional — disabled without this) ─────────────────────────
# Discord channel for the standing #comms-cal days-of-significance embed
# COMMS_CALENDAR_CHANNEL_ID=

# ── YouTube Announcements (optional — disabled without this) ──────────────────
# YouTube channel ID to poll for new uploads
# YOUTUBE_CHANNEL_ID=

# Discord channel to post new-video announcements in
# ANNOUNCEMENTS_CHANNEL_ID=

# ── Events Calendar (optional — disabled without this) ────────────────────────
# Discord channel for the standing Upcoming Event Schedule embed
# EVENTS_CALENDAR_CHANNEL_ID=

# Role pinged on event created/changed and 15-min-before reminders
# TUNED_ROLE_ID=

# The "Fusion Public & Member Events" Google Calendar ID
# GOOGLE_CALENDAR_ID=

# Read-only Google Calendar API key — write direction (Discord -> Google) not yet
# implemented, see TODO in governance/events-calendar/googleCalendar.ts
# GOOGLE_CALENDAR_API_KEY=

# ── Upvote Relay (optional — disabled without this) ───────────────────────────
# Bluesky account handle to watch for new posts, e.g. fusionparty.bsky.social
# BLUESKY_HANDLE=

# Discord channel for relaying new Bluesky posts (#upvote-this)
# UPVOTE_CHANNEL_ID=
